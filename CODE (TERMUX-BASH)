R='\033[1;31m'
Y='\033[1;33m'
G='\033[1;32m'
C='\033[1;36m'
M='\033[1;35m'
W='\033[1;37m'
D='\033[0;90m'
N='\033[0m'
BOLD='\033[1m'

# ── Utilidades ────────────────────────────────────────────────
pause() {
    echo ""
    echo -e "  ${D}[ presiona ENTER para volver ]${N}"
    read -r
}

section() {
    clear
    echo -e "${C}"
    echo -e "  ╔══════════════════════════════════════════╗"
    printf "  ║  ${W}${BOLD}%-40s${C}║\n" "$1"
    echo -e "  ╚══════════════════════════════════════════╝${N}"
    echo ""
}

result_ok()   { echo -e "  ${G}✔${N} ${W}$1:${N} ${G}$2${N}"; }
result_warn() { echo -e "  ${Y}⚠${N} ${W}$1:${N} ${Y}$2${N}"; }
result_bad()  { echo -e "  ${R}✘${N} ${W}$1:${N} ${R}$2${N}"; }
result_info() { echo -e "  ${C}▸${N} ${W}$1:${N} ${D}$2${N}"; }

open_url() {
    local url="$1"
    if command -v termux-open-url &>/dev/null; then
        termux-open-url "$url" 2>/dev/null
    else
        echo -e "  ${D}URL: $url${N}"
        echo -e "  ${D}(instala termux-tools para abrir en navegador)${N}"
    fi
}

# ── Auto-instalador de dependencias ──────────────────────────
check_and_install() {
    local pkg="$1"
    local cmd="${2:-$1}"
    if ! command -v "$cmd" &>/dev/null; then
        echo -e "  ${Y}Instalando ${W}${pkg}${Y}...${N}"
        pkg install -y "$pkg" 2>/dev/null
    fi
}

install_deps() {
    section "Instalando dependencias necesarias"
    echo -e "  ${Y}Verificando e instalando dependencias para Termux...${N}"
    echo ""
    pkg update -y 2>/dev/null | tail -1
    echo ""
    for dep in curl jq nmap openssl-tool dnsutils whois netcat-openbsd; do
        if command -v "${dep%%-*}" &>/dev/null || pkg list-installed 2>/dev/null | grep -q "^${dep}"; then
            result_ok "$dep" "Ya instalado"
        else
            echo -ne "  ${Y}Instalando $dep...${N}"
            pkg install -y "$dep" 2>/dev/null && echo -e " ${G}✔${N}" || echo -e " ${R}✘${N}"
        fi
    done
    echo ""
    result_ok "Dependencias" "Listas"
    pause
}

